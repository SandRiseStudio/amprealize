# PostgreSQL DSN Configuration Template
# Copy to deployment/environments/{env}.env and customize for each environment

# Telemetry Service Database
AMPREALIZE_TELEMETRY_PG_DSN=postgresql://amprealize_telemetry:REPLACE_PASSWORD@REPLACE_HOST:5432/telemetry

# Behavior Service Database
AMPREALIZE_BEHAVIOR_PG_DSN=postgresql://amprealize_behavior:REPLACE_PASSWORD@REPLACE_HOST:5432/behaviors

# Workflow Service Database
AMPREALIZE_WORKFLOW_PG_DSN=postgresql://amprealize_workflow:REPLACE_PASSWORD@REPLACE_HOST:5432/workflows

# Action Service Database (future)
# AMPREALIZE_ACTION_PG_DSN=postgresql://amprealize_action:REPLACE_PASSWORD@REPLACE_HOST:5432/actions

# Compliance Service Database (future)
# AMPREALIZE_COMPLIANCE_PG_DSN=postgresql://amprealize_compliance:REPLACE_PASSWORD@REPLACE_HOST:5432/compliance

# Migration Settings
AMPREALIZE_MIGRATION_VERBOSE=1
AMPREALIZE_MIGRATION_BATCH_SIZE=1000

# Security Notes:
# - Never commit real passwords to version control
# - Use secrets manager for production (see SECRETS_MANAGEMENT_PLAN.md)
# - Enable SSL/TLS in production: add ?sslmode=require to DSN
# - Rotate credentials regularly per security policy
