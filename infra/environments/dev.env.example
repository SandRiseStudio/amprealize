# Amprealize Development Environment Configuration
# Copy this file to dev.env and fill in actual values

# API Configuration
AMPREALIZE_GATEWAY_URL=https://dev.amprealize.com
AMPREALIZE_API_PORT=8000
AMPREALIZE_ENV=development

# Database
DATABASE_URL=postgresql://amprealize_dev:password@localhost:5432/amprealize_dev
DUCKDB_PATH=data/telemetry_dev.duckdb

# Authentication
AMPREALIZE_DEVICE_FLOW_CLIENT_ID=amprealize-dev-client
AMPREALIZE_DEVICE_FLOW_AUTH_URL=https://dev-auth.amprealize.com
AMPREALIZE_ALLOW_PLAINTEXT_TOKENS=true  # Dev only!

# Telemetry & Analytics
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=amprealize-telemetry-dev
TELEMETRY_SINK_TYPE=file  # file | kafka | both
TELEMETRY_FILE_PATH=data/telemetry_dev.jsonl

# Secrets Management
TOKEN_STORE_TYPE=file  # file | keychain (dev uses file for simplicity)
TOKEN_STORE_PATH=~/.amprealize/dev/tokens.json

# Feature Flags
ENABLE_MCP_SERVER=true
ENABLE_DEVICE_FLOW=true
ENABLE_ANALYTICS_DASHBOARD=true
ENABLE_COMPLIANCE_AUTOMATION=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=json
STRUCTURED_LOGGING=true

# CORS (dev allows all origins)
ALLOWED_ORIGINS=*

# Rate Limiting (relaxed for dev)
RATE_LIMIT_ENABLED=false
